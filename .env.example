# ---- Ogma gateway config ----  (copy to .env, then `chmod 600 .env`)

# REQUIRED: from @BotFather in Telegram (/newbot)
TELEGRAM_BOT_TOKEN=

# REQUIRED: comma-separated Telegram chat IDs allowed to use the bot.
# Leave empty on first run, message the bot, and it will reply with your chat ID.
TELEGRAM_ALLOWED_USERS=

# --- optional: paths / runtime ---
# Path to the claude CLI (default: ~/.local/bin/claude)
# CLAUDE_BIN=/home/youruser/.local/bin/claude

# Working directory Claude runs in (holds its CLAUDE.md persona)
# OGMA_WORKDIR=/home/youruser/ogma/workspace

# Per-message timeout in seconds (default 300)
# CLAUDE_TIMEOUT=300

# Max concurrent Claude runs across all chats (default 1). Keep at 1 on small boxes
# (a Pi can OOM if several run at once); raise only on a roomy host.
# OGMA_MAX_CONCURRENT=1

# --- optional: permissions / model ---
# Permission posture for tools. Empty = safest (tools needing approval are skipped).
# Set to "acceptEdits" to let it edit files, or use OGMA_ALLOWED_TOOLS for a curated set.
# OGMA_PERMISSION_MODE=

# Space-separated allowed tools, e.g. "Read WebSearch WebFetch Glob Grep"
# To let the bot manage itself, add the ogmactl path rule (use YOUR absolute path):
#   OGMA_ALLOWED_TOOLS=Read WebSearch WebFetch Glob Grep Bash(/home/youruser/ogma/bin/ogmactl:*)
# OGMA_ALLOWED_TOOLS=

# Override model for the gateway (default = your Claude Code default)
# OGMA_MODEL=sonnet

# Fallback model used automatically if the main model is unavailable (rate limit/outage).
# Alias or full id; blank = none. Changeable live from chat via /fallback.
# OGMA_FALLBACK_MODEL=

# Reasoning effort for the gateway: low | medium | high | xhigh | max (blank = CLI default)
# Higher = more thorough but slower/pricier. Changeable live from chat via /effort.
# OGMA_EFFORT=

# Model for the nightly dream/memory-consolidation job (default: claude-sonnet-4-6).
# Use the explicit standard-context id, not the bare 'sonnet' alias: in headless runs
# the alias can resolve to the credit-gated 1M-context variant and fail with
# "Usage credits required for 1M context". The explicit id forces the 200k window.
# OGMA_DREAM_MODEL=claude-sonnet-4-6

# --- optional: briefing / news ---
# Who the morning briefing is addressed to (default: "you")
# OGMA_OWNER_NAME=

# wttr.in weather location, e.g. "Vienna" or "Berlin" (default: empty = geolocate by IP)
# OGMA_WEATHER_LOC=

# --- optional: persona overrides ---
# Rendered by bin/setup into the gitignored workspace/CLAUDE.local.md overlay (also
# settable live with: bin/ogmactl set-persona <field> <value>). All blank = Ogma's defaults.
# Bot name — replaces "Ogma" in the persona, e.g. "Aria" or "Max".
# OGMA_PERSONA_NAME=
# Conversation style/tone override, free text, e.g. "terse and dry" or "more formal".
# OGMA_PERSONA_STYLE=
# Default language — reply in this even when written to in another, e.g. "German".
# OGMA_PERSONA_LANG=

# RSS feeds for news-fetch: comma-separated Label|url pairs.
# OGMA_RSS_FEEDS=BBC World|http://feeds.bbci.co.uk/news/world/rss.xml,Guardian World|https://www.theguardian.com/world/rss
