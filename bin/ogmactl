#!/usr/bin/env bash
# ogmactl — tightly-scoped self-management for the Ogma gateway.
#
# This is the ONLY shell command the Telegram bot is permitted to run. It accepts
# a fixed whitelist of subcommands and refuses everything else, so granting the bot
# access to this script does NOT grant it arbitrary shell on the box.
set -uo pipefail

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
BASE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SVC="ogma-gateway"
LOG="$BASE/gateway.log"
ENV="$BASE/.env"
TICKETS="$BASE/tickets"
# Optional, operator-provided, gitignored extension for host-specific commands
# (e.g. a Pi-hole diagnostic). Keeps the public tool host-agnostic. See the *) case.
LOCAL="$BASE/bin/ogmactl.local"

usage() {
  echo "ogmactl: allowed commands — status | logs [source] [N] | restart | health | backup | remember [--type T] <text> | set-persona <field> [value] | ticket <text> | tickets"
  echo "          log sources: gateway (default), dream, briefing"
  echo "          remember types: user | feedback | project (default) | reference"
  echo "          set-persona fields: name | style | language | show | clear"
  [ -x "$LOCAL" ] && "$LOCAL" help 2>/dev/null
}

# Read a config value (OGMA_<name>) from .env.
cfg() {
  grep -E "^OGMA_${1}=" "$ENV" 2>/dev/null | cut -d= -f2-
}

cmd="${1:-}"
case "$cmd" in
  status)
    echo "service : $(systemctl --user is-active "$SVC" 2>/dev/null || echo unknown)"
    up="$(systemctl --user show "$SVC" -p ActiveEnterTimestamp --value 2>/dev/null)"
    echo "since   : ${up:-?}"
    echo "model   : $(cfg MODEL || echo default)"
    ;;
  logs)
    # Accept both `logs [N]` (gateway, back-compat) and `logs <source> [N]`.
    # The nightly jobs (dream, briefing) write to their own files, so without a
    # source selector the bot could only ever see the gateway log — which is why
    # it wrongly reported the dream "not running". Map a small whitelist of names
    # to Ogma's per-subsystem logs; default to the gateway log.
    src="gateway"; n=30
    if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
      n="$2"
    elif [ -n "${2:-}" ]; then
      src="$2"
      [[ "${3:-}" =~ ^[0-9]+$ ]] && n="$3"
    fi
    case "$src" in
      gateway)  file="$LOG" ;;
      dream)    file="$BASE/dream.log" ;;
      briefing) file="$BASE/briefing.log" ;;
      *) echo "usage: ogmactl logs [source] [N]   (source: gateway|dream|briefing)"; exit 2 ;;
    esac
    if ! [[ "$n" =~ ^[0-9]+$ ]] || (( n < 1 || n > 200 )); then
      echo "usage: ogmactl logs [source] [N]   (N = 1..200 lines)"; exit 2
    fi
    tail -n "$n" "$file" 2>/dev/null || echo "(no $src log yet)"
    ;;
  restart)
    # Schedule a detached restart in its own transient scope so it survives this
    # process (and the whole service cgroup) being torn down by the restart.
    if systemd-run --user --on-active=8 \
         systemctl --user restart "$SVC" >/dev/null 2>&1; then
      echo "✅ Restart scheduled in ~8s. I'll be back momentarily."
    else
      echo "⚠️ Could not schedule restart (systemd-run --user failed)."; exit 1
    fi
    ;;
  health)
    echo "uptime  : $(uptime -p 2>/dev/null || cut -d. -f1 /proc/uptime)"
    echo "load    : $(cut -d' ' -f1-3 /proc/loadavg)"
    if [ -r /sys/class/thermal/thermal_zone0/temp ]; then
      echo "temp    : $(( $(cat /sys/class/thermal/thermal_zone0/temp) / 1000 ))°C"
    fi
    echo "memory  : $(free -h | awk 'NR==2{print $3" used / "$2}')"
    echo "disk /  : $(df -h / | awk 'NR==2{print $3" used / "$2" ("$5")"}')"
    ;;
  backup)
    # Let the bot (or operator) trigger an on-demand host-local backup. Delegates to
    # bin/backup, which archives the git-ignored host files to ~/ogma-backups (outside
    # the repo). Uninstall is deliberately NOT exposed here — backups only.
    bk="$BASE/bin/backup"
    [ -x "$bk" ] || { echo "backup helper missing ($bk)"; exit 1; }
    exec "$bk"
    ;;
  remember)
    # Let the bot persist a memory immediately (and confirm in its reply). Writing via plain
    # shell sidesteps Claude Code's "sensitive path" tool guard that blocks the gateway (cwd=
    # workspace) from writing the home-project memory dir. The nightly dream pass consolidates
    # and re-types these later, so a quick capture with a sane default type is fine.
    shift
    type="project"
    if [ "${1:-}" = "--type" ]; then
      case "${2:-}" in
        user|feedback|project|reference) type="$2"; shift 2 ;;
        *) echo "usage: ogmactl remember [--type user|feedback|project|reference] <text>"; exit 2 ;;
      esac
    fi
    body="$*"
    [ -n "$body" ] || { echo "usage: ogmactl remember [--type T] <text>"; exit 2; }
    # Home-project auto-memory dir (derive from $HOME, slashes -> dashes), matching bin/dream.
    MEM="$HOME/.claude/projects/$(printf '%s' "$HOME" | sed 's#/#-#g')/memory"
    mkdir -p "$MEM"
    # One-line description / slug from the text; fall back to a timestamp slug.
    desc="$(printf '%s' "$body" | tr '\n' ' ' | sed 's/  */ /g; s/^ //; s/ $//')"
    desc="${desc:0:80}"
    slug="$(printf '%s' "$desc" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-*//; s/-*$//' | cut -c1-40 | sed 's/-*$//')"
    [ -n "$slug" ] || slug="note-$(date +%Y%m%d-%H%M%S)"
    f="$MEM/$slug.md"
    [ -e "$f" ] && { slug="$slug-$(date +%H%M%S)"; f="$MEM/$slug.md"; }
    {
      echo "---"
      echo "name: $slug"
      echo "description: $desc"
      echo "metadata:"
      echo "  type: $type"
      echo "---"
      echo
      echo "$body"
    } > "$f"
    # Keep the index in sync: ensure a header, then append a one-line pointer.
    idx="$MEM/MEMORY.md"
    [ -f "$idx" ] || printf '# Memory Index\n\n' > "$idx"
    printf -- '- [%s](%s.md) — %s\n' "$slug" "$slug" "$desc" >> "$idx"
    echo "🧠 Remembered ($type) — saved as $slug.md. The nightly consolidation will refine it."
    ;;
  set-persona)
    # Let the bot (or the operator) rename itself and tweak its tone/default language.
    # Values are stored in .env and rendered into workspace/CLAUDE.local.md (the gitignored
    # overlay imported by the persona), so they survive a `bin/setup` re-run and a `git pull`.
    # The change is read at the next session start — hence the restart hint.
    shift
    field="${1:-}"; shift 2>/dev/null || true
    val="$*"
    src="$BASE/bin/_persona.sh"
    [ -r "$src" ] || { echo "persona helper missing ($src)"; exit 1; }
    # shellcheck source=/dev/null
    . "$src"
    case "$field" in
      name)     persona_set_env "$ENV" OGMA_PERSONA_NAME  "$val" ;;
      style)    persona_set_env "$ENV" OGMA_PERSONA_STYLE "$val" ;;
      language) persona_set_env "$ENV" OGMA_PERSONA_LANG  "$val" ;;
      clear)
        persona_set_env "$ENV" OGMA_PERSONA_NAME  ""
        persona_set_env "$ENV" OGMA_PERSONA_STYLE ""
        persona_set_env "$ENV" OGMA_PERSONA_LANG  "" ;;
      show)
        n="$(persona_cfg "$ENV" NAME)"; s="$(persona_cfg "$ENV" STYLE)"; l="$(persona_cfg "$ENV" LANG)"
        printf 'name     : %s\n' "${n:-(default: Ogma)}"
        printf 'style    : %s\n' "${s:-(default)}"
        printf 'language : %s\n' "${l:-(default: match the user)}"
        exit 0 ;;
      *) echo "usage: ogmactl set-persona <name|style|language|show|clear> [value]"; exit 2 ;;
    esac
    WS="$(cfg WORKDIR)"; [ -n "$WS" ] || WS="$BASE/workspace"
    MD="$WS/CLAUDE.local.md"
    [ -f "$MD" ] || { echo "no CLAUDE.local.md yet — run bin/setup first."; exit 1; }
    persona_render "$ENV" "$MD"
    echo "✅ Persona updated. Restart to apply it: ogmactl restart"
    ;;
  ticket)
    shift
    body="$*"
    [ -n "$body" ] || { echo "usage: ogmactl ticket <description>"; exit 2; }
    mkdir -p "$TICKETS"
    id="$(date +%Y%m%d-%H%M%S)"
    f="$TICKETS/${id}.md"
    {
      echo "---"
      echo "id: $id"
      echo "created: $(date '+%F %T %Z')"
      echo "status: open"
      echo "source: telegram"
      echo "---"
      echo
      echo "$body"
    } > "$f"
    echo "🎫 Ticket $id filed. Pick it up in an interactive session."
    ;;
  tickets)
    shopt -s nullglob
    files=("$TICKETS"/*.md)
    if (( ${#files[@]} == 0 )); then echo "No open tickets."; exit 0; fi
    echo "Open tickets (${#files[@]}):"
    for f in "${files[@]}"; do
      id="$(basename "$f" .md)"
      sum="$(awk '/^---$/{d++; next} d>=2 && NF{print; exit}' "$f")"
      echo "• $id — ${sum:0:80}"
    done
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    # Delegate to the optional host-local extension if the operator installed one.
    # It MUST whitelist its own subcommands and refuse the rest (same discipline as
    # this script), since the bot can reach it through ogmactl. On a stock install
    # there is no such file and unknown commands are refused, as before.
    if [ -x "$LOCAL" ]; then
      exec "$LOCAL" "$@"
    fi
    echo "ogmactl: refused unknown command '$cmd'"; usage; exit 2
    ;;
esac
