{
  "permissions": {
    "allow": [
      "Bash({{OGMA_DIR}}/bin/ogmactl:*)"
    ],
    "additionalDirectories": [
      "{{MEMORY_DIR}}"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{OGMA_DIR}}/hooks/persist-nudge.py",
            "timeout": 10,
            "statusMessage": "Checking for anything worth remembering…"
          }
        ]
      }
    ]
  }
}
